# .gitignore for Smart Vision Alert

# Environment / secrets
config/.env
.env
xiaomi_devices.json
config/.micloud_session
config/.micloud_session_new
config/.telegram_offset

# Captures (all runtime data)
captures/*
!captures/manual/
captures/manual/*
!captures/manual/.gitkeep

# Logs
logs/*.log
logs/.last_alert.json

# macOS
**/.DS_Store

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
