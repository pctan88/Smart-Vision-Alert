# ============================================
# Smart Vision Alert — Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp config/.env.example config/.env

# --- Xiaomi Cloud ---
XIAOMI_USERNAME=your_email@example.com
XIAOMI_PASSWORD=your_password
XIAOMI_SERVER_REGION=sg
# Regions: cn (China), de (Germany), us (USA), sg (Singapore),
#          in (India), ru (Russia), tw (Taiwan)

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key
# Get from: https://aistudio.google.com/apikey

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_group_chat_id
# Create bot via @BotFather, add to group, get chat_id

# --- App Settings ---
CAPTURE_INTERVAL_SECONDS=300
IMAGE_MAX_SIZE_KB=500
LOG_LEVEL=INFO

# Cooldown between alerts (minutes) — prevents spam
ALERT_COOLDOWN_MINUTES=15

# Risk level threshold to trigger alert: low, medium, high, critical
ALERT_THRESHOLD=medium

# --- Multi-Frame Analysis ---
# Compare multiple frames to detect motion/stillness (recommended for aerial studios)
MULTI_FRAME_ENABLED=true

# Number of frames to compare (2-5, more = better detection but more API tokens)
MULTI_FRAME_COUNT=3

# Seconds between burst captures (for url/xiaomi_cloud modes)
MULTI_FRAME_INTERVAL_SECONDS=5

# --- Camera Source Mode ---
# Options: "xiaomi_cloud", "local_folder", "url"
#   xiaomi_cloud = Pull from Xiaomi Cloud API (needs token)
#   local_folder = Read latest image from captures/manual/ folder
#   url          = Download from a direct image URL
CAMERA_SOURCE=local_folder

# For "url" mode only:
CAMERA_SNAPSHOT_URL=

# --- Storage ---
# Max days to keep captured images
CAPTURE_RETENTION_DAYS=3
